# tape-archiver data worker — reference environment file.
#
# Copy to /etc/tape-archiver/data-worker.env and fill in for this host. Both the
# systemd unit's EnvironmentFile and `docker run --env-file` read this file, so
# it is the single source of run configuration — nothing is hardcoded in the
# unit. Lines are KEY=value (no `export`, no shell quoting rules); `#` comments
# and blank lines are ignored.

# --- Required ---------------------------------------------------------------

# Selects the data task queue and the bulk-data activity set (SPEC §4.1). Do not
# change; this unit runs the data worker.
ROLE=data

# Temporal frontend the worker connects to (host:port, no scheme) and the
# namespace its workflows run in. Consumed by the Temporal SDK envconfig loader.
TEMPORAL_ADDRESS=temporal-frontend.example.internal:7233
TEMPORAL_NAMESPACE=default

# Staging root for the Prepare phase — a plain subdirectory of an existing
# dataset on the pool, under the bind-mounted /mnt/bulk-pool-01 so it is visible
# in the container (SPEC §4.1, §4.3). The worker never runs `zfs create`.
TAPE_STAGING_DIR=/mnt/bulk-pool-01/archive/.tape-staging

# --- Optional ---------------------------------------------------------------

# The static recovery binaries (age, par2, zstd, tar) and their upstream source
# archives the Report phase stages into the recovery ISO (SPEC §10) are baked
# into the image at /recovery/{bin,src} — from the same pinned nixpkgs as the
# rest of the tooling, so the disc can never drift from the write path. The image
# already points these at the baked-in copies; set them only to relocate the set.
#TAPE_RECOVERY_BINARIES_DIR=/recovery/bin
#TAPE_RECOVERY_SOURCES_DIR=/recovery/src

# Log verbosity passed verbatim to the worker (empty defaults to info).
#LOG_LEVEL=info

# Discord webhook the data worker delivers the report/ISO and failure alerts to
# (SPEC §4.1, §11). Leave unset to disable delivery.
#DISCORD_FAILURE_WEBHOOK_URL=https://discord.com/api/webhooks/...

# democratic-csi datasetParentName, prepended to a relative CSI snapshotHandle to
# rebuild an absolute ZFS snapshot path (SPEC §3). Only needed when a run names
# k8s sources.
#TAPE_K8S_DATASET_PARENT=bulk-pool-01/k8s

# Prometheus /metrics listen address (default :9090). Set to empty to disable.
#METRICS_ADDR=:9090

# Health/readiness probe listen address the image HEALTHCHECK targets
# (default :8080). Set to empty to disable the endpoints.
#HEALTH_ADDR=:8080

# Temporal API key / TLS material for an authenticated frontend (Temporal Cloud
# or a secured self-hosted frontend). Consumed by the envconfig loader.
#TEMPORAL_API_KEY=...
#TEMPORAL_TLS=true

# Graceful-stop budget in seconds handed to `docker stop --time` on service
# stop. Default 300. Raise it (and TimeoutStopSec in the unit, which must stay
# larger) if the worker must finish a long in-flight write before shutdown.
#TAPE_ARCHIVER_STOP_TIMEOUT=300
